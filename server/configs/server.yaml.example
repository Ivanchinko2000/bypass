# ================================================
# Конфигурация bypass-server
# Режим: РФ (rf) — сервер с WDTT + WireGuard + Zapret
# ================================================

# Режим работы: "rf" (РФ-сервер) или "eu" (ЕС-сервер)
# РФ: WDTT терминация + WireGuard + Zapret + Xray клиент
# ЕС: VLESS+Reality сервер через Xray
mode: rf

# ================================================
# Адреса для прослушивания
# ================================================
listen:
  # HTTP API для управления (статистика, пользователи)
  api_addr: ":8080"

  # Адрес DoH DNS-резолвера (для клиентов в WG-туннеле)
  dns_addr: ":53"

  # UDP-порт для WDTT DTLS-терминации (главный порт для Android-клиентов)
  # Клиенты подключаются сюда по DTLS поверх обфусцированного RTP
  wdtt_dtls_addr: "0.0.0.0:56000"

  # Локальный SOCKS5 прокси для маршрутизации geo-трафика к Xray
  # Используется для направления geo-запросов через VLESS+Reality туннель к ЕС
  socks5_addr: "127.0.0.1:1080"

# ================================================
# WireGuard — настройки userspace WireGuard
# ================================================
wireguard:
  # Имя TUN-интерфейса (создаётся автоматически)
  interface_name: "bypass0"

  # Приватный ключ сервера WireGuard (base64)
  # Генерируется: wg genkey | base64
  private_key: "ВСТАВЬТЕ_ВАШ_ПРИВАТНЫЙ_КЛЮЧ"

  # Подсеть для WireGuard клиентов
  subnet: "10.66.0.0/16"

  # IP адрес сервера в подсети
  server_ip: "10.66.66.1"

  # MTU для WireGuard (не более 1280 для DTLS-инкапсуляции)
  mtu: 1280

  # Интервал keepalive для клиентов (секунды)
  keepalive: 25

  # Внутренний UDP-порт WireGuard (на localhost, не снаружи)
  # WDTT проксирует DTLS → этот порт
  internal_port: 56001

# ================================================
# WDTT — настройки DTLS-терминации (только для РФ-сервера)
# ================================================
wdtt:
  # Включить WDTT терминацию
  enabled: true

  # UDP-адрес для DTLS (дублирует listen.wdtt_dtls_addr для обратной совместимости)
  dtls_addr: "0.0.0.0:56000"

  # Главный пароль WDTT (используется для HKDF вывода WRAP-ключа)
  # Этот пароль также проверяется первым при аутентификации клиентов
  password: "СГЕНЕРИРУЙТЕ_НАДЁЖНЫЙ_ПАРОЛЬ"

# ================================================
# VLESS+Reality — туннель между РФ и ЕС серверами
# ================================================
vless:
  # Роль: "server" (ЕС-терминирует) или "client" (РФ подключается к ЕС)
  role: "client"

  # Настройки VLESS сервера (только для ЕС-сервера)
  server:
    listen: ":443"
    private_key: ""      # Reality приватный ключ ЕС-сервера
    short_id: "abcd1234"
    dest: "www.microsoft.com:443"
    server_names:
      - "www.microsoft.com"
      - "microsoft.com"

  # Настройки VLESS клиента (РФ-сервер → ЕС-сервер)
  client:
    # Включить исходящий VLESS+Reality туннель
    enabled: true

    # Адрес ЕС-сервера (host:port)
    remote_addr: "1.2.3.4:443"

    # UUID для аутентификации на ЕС-сервере
    uuid: "СГЕНЕРИРУЙТЕ_UUID"

    # Reality публичный ключ ЕС-сервера
    public_key: "ВСТАВЬТЕ_ПУБЛИЧНЫЙ_КЛЮЧ"

    # Reality shortId (должен совпадать с сервером)
    short_id: "abcd1234"

    # TLS fingerprint для камуфляжа (chrome, firefox, safari, etc.)
    fingerprint: "chrome"

    # SNI для камуфляжа
    server_name: "www.microsoft.com"

    # Путь к Xray-core бинарнику
    xray_path: "/usr/local/bin/xray-core"

    # Путь к генерируемому конфигу Xray
    xray_config_path: "configs/xray_config.json"

# ================================================
# Zapret — обход DPI (только для РФ-сервера)
# ================================================
zapret:
  # Включить интеграцию с Zapret (nfqws)
  enabled: true

  # Путь к бинарнику nfqws
  nfqws_path: "/usr/bin/nfqws"

  # Аргументы запуска nfqws
  # --warp-crypto=auto — автоматический режим обфускации
  # --host-another — SNI подмена для обхода DPI
  # --host-pfx — количество пакетов с подменённым SNI
  nfqws_args: "--warp-crypto=auto --host-another=sni.yandex.net --host-pfx=2"

  # Номер NFQUEUE (по умолчанию 200)
  qnum: 200

# ================================================
# DNS — настройки DNS-резолвера
# ================================================
dns:
  # Включить DNS-резолвер для WG-клиентов
  enabled: true

  # Адрес для прослушивания
  listen: ":53"

  # Upstream DNS серверы (для обычных запросов)
  upstream:
    - "1.1.1.1"
    - "8.8.8.8"

  # Upstream DNS для geo-запросов (через туннель к ЕС)
  # Если пусто — используется upstream
  eu_upstream:
    - "1.1.1.1"
    - "8.8.8.8"

  # Включить DoH listener
  enable_doh: false

  # TTL кэша DNS (секунды)
  cache_ttl: 300

# ================================================
# HTTP API
# ================================================
api:
  # Включить HTTP API
  enabled: true

  # Адрес для прослушивания
  listen: ":8080"

  # Токен авторизации для административных запросов
  # Используется в заголовке Authorization: Bearer <token>
  auth_token: "СГЕНЕРИРУЙТЕ_ТОКЕН"

# ================================================
# Путь к файлу пользователей
# ================================================
users_file: "configs/users.json"

# ================================================
# Пути к файлам списков
# ================================================
lists:
  # DPI-блоклист: домены, блокируемые по сигнатурам (YouTube, Instagram и т.д.)
  dpi_blocklist: "configs/dpi_blocklist.txt"

  # Geo-блоклист: сервисы, географически недоступные в РФ
  geo_blocklist: "configs/geo_blocklist.txt"

# ================================================
# Логирование
# ================================================
log_level: "info"        # debug, info, warn, error
log_file: ""             # пусто = stdout